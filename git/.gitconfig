[user]
	name = huaqianlee
	email = huaqianlee@gmail.com

[color]
	ui = auto

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current

[pull]
	rebase = true

[merge]
	conflictStyle = zdiff3

[rerere]
	enabled = true

# credential helper — platform specific
# macOS: git config --global credential.helper osxkeychain
# Linux: git config --global credential.helper store

[core]
	editor = vim

[alias]
	# status
	st = status
	ss = status -s

	# log
	lo = log --oneline
	lg = log --oneline --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	l = log --oneline --graph
	last = log -1 HEAD
	tree = log --oneline --graph --all

	# diff
	df = diff
	dc = diff --cached
	dt = difftool

	# commit
	cm = commit
	ca = commit --amend
	sneak = commit -a --amend --no-edit

	# branch
	br = branch
	bv = branch -vv

	# checkout
	co = checkout
	cob = checkout -b

	# cherry-pick
	cp = cherry-pick

	# reset / undo
	undo = reset --soft HEAD^
	unstage = reset HEAD --

	# rebase
	rb = rebase
	rbi = rebase -i

	# fetch / push / pull
	f = fetch
	p = push
	pl = pull --rebase

	# stash
	pop = stash pop
	sa = stash save
	sl = stash list

	# misc
	alias = !git config --list | grep 'alias\\.' | sed 's/alias\\.//g'
	contributors = shortlog -s --
	ignore = !git ls-files -i --exclude-standard
